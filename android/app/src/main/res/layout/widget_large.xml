<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container_large"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <!-- 헤더 (고정 높이) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/widget_title_large"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="  유치부"
            android:textSize="16dp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/widget_refresh_large"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↻"
            android:textSize="18dp"
            android:textColor="@color/app_primary"
            android:paddingStart="8dp"
            android:paddingEnd="0dp" />
    </LinearLayout>

    <!-- 지난 주 (weight 균등 분배) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/section_bg"
        android:padding="8dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/last_week_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="지난 주"
            android:textSize="11dp"
            android:textStyle="bold"
            android:textColor="@color/text_muted"
            android:paddingBottom="2dp" />

        <TextView
            android:id="@+id/last_week_lesson"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13dp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingBottom="2dp" />

        <TextView
            android:id="@+id/last_week_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:textSize="11dp"
            android:textColor="@color/text_primary"
            android:maxLines="3"
            android:ellipsize="end"
            android:lineSpacingExtra="2dp" />

        <TextView
            android:id="@+id/last_week_reference"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="10dp"
            android:textColor="@color/app_primary"
            android:textStyle="bold"
            android:gravity="end"
            android:paddingTop="2dp" />
    </LinearLayout>

    <!-- 이번 주 (weight 균등 분배, 강조) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/section_accent"
        android:padding="8dp"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/this_week_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="★ 이번 주"
            android:textSize="11dp"
            android:textStyle="bold"
            android:textColor="@color/app_primary"
            android:paddingBottom="2dp" />

        <TextView
            android:id="@+id/this_week_lesson"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13dp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingBottom="2dp" />

        <TextView
            android:id="@+id/this_week_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:textSize="11dp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:maxLines="3"
            android:ellipsize="end"
            android:lineSpacingExtra="2dp" />

        <TextView
            android:id="@+id/this_week_reference"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="10dp"
            android:textColor="@color/app_primary_dark"
            android:textStyle="bold"
            android:gravity="end"
            android:paddingTop="2dp" />
    </LinearLayout>

    <!-- 다음 주 (weight 균등 분배) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/section_bg"
        android:padding="8dp">

        <TextView
            android:id="@+id/next_week_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="다음 주"
            android:textSize="11dp"
            android:textStyle="bold"
            android:textColor="@color/text_muted"
            android:paddingBottom="2dp" />

        <TextView
            android:id="@+id/next_week_lesson"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13dp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingBottom="2dp" />

        <TextView
            android:id="@+id/next_week_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:textSize="11dp"
            android:textColor="@color/text_primary"
            android:maxLines="3"
            android:ellipsize="end"
            android:lineSpacingExtra="2dp" />

        <TextView
            android:id="@+id/next_week_reference"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="10dp"
            android:textColor="@color/app_primary"
            android:textStyle="bold"
            android:gravity="end"
            android:paddingTop="2dp" />
    </LinearLayout>

</LinearLayout>
