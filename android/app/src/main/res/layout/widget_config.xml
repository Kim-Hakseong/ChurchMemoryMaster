<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F8F9FA">

    <!-- 헤더 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="부서 선택"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:paddingBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="위젯에 표시할 부서를 선택하세요"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:paddingBottom="20dp" />

    <!-- 유치부 -->
    <LinearLayout
        android:id="@+id/btn_kindergarten"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_config_card"
        android:padding="14dp"
        android:layout_marginBottom="8dp"
        android:clickable="true"
        android:focusable="true">

        <View
            android:layout_width="5dp"
            android:layout_height="28dp"
            android:background="@drawable/widget_config_indicator"
            android:backgroundTint="@color/pink_600"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="유치부"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="20sp"
            android:textColor="@color/text_muted" />
    </LinearLayout>

    <!-- 초등부 -->
    <LinearLayout
        android:id="@+id/btn_elementary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_config_card"
        android:padding="14dp"
        android:layout_marginBottom="8dp"
        android:clickable="true"
        android:focusable="true">

        <View
            android:layout_width="5dp"
            android:layout_height="28dp"
            android:background="@drawable/widget_config_indicator"
            android:backgroundTint="@color/blue_600"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="초등부"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="20sp"
            android:textColor="@color/text_muted" />
    </LinearLayout>

    <!-- 중고등부 -->
    <LinearLayout
        android:id="@+id/btn_youth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_config_card"
        android:padding="14dp"
        android:layout_marginBottom="8dp"
        android:clickable="true"
        android:focusable="true">

        <View
            android:layout_width="5dp"
            android:layout_height="28dp"
            android:background="@drawable/widget_config_indicator"
            android:backgroundTint="@color/green_600"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="중고등부"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="20sp"
            android:textColor="@color/text_muted" />
    </LinearLayout>


</LinearLayout>
